#!/usr/bin/env python3
"""invisible-server — VPS daemon for cross-machine state sync.

The MAC and WINDOWS orchestrators each run their loops locally (codex and
claude need per-machine auth). On every `checkpoint.save()` they POST the
state to this daemon at /api/events. The daemon persists to SQLite and
broadcasts the event via Server-Sent Events to subscribed clients
(dashboard web page, tray apps).

The daemon ALSO scans for VPS-local runs — if this VPS is doing its own
orchestrator work (e.g. via `invisible-vps-handoff` or a native run), the
poller picks those checkpoints up from $INVISIBLE_HOME/worktrees/ on this
machine and ingests them as if they'd been pushed.

Endpoints:
    GET  /                  HTML index (lists projects from SQLite + Notion)
    GET  /p/<project>       HTML drilldown
    GET  /api/projects      JSON list of (machine, project, state)
    GET  /api/p/<project>   JSON detail, latest across all machines
    GET  /api/reviews       JSON tail of Notion Reviews (cross-machine truth)
    GET  /api/stream        SSE: server pushes 'data: {...}\\n\\n' per event
    POST /api/events        Ingest endpoint (laptops push checkpoint state)
    GET  /healthz           200 OK, no auth (for nginx / Cloudflare probes)

Auth:
    Bearer token on every route except /healthz.
    Source: $INVISIBLE_SERVER_TOKEN (must be set; daemon refuses to start
    without it unless --no-auth + --host 127.0.0.1).

Database:
    $INVISIBLE_SERVER_DB or /var/lib/invisible/state.db (auto-created).

Local poll:
    Scans $INVISIBLE_HOME/worktrees/* every $INVISIBLE_SERVER_POLL_SECS (default 10s).
    Disable by setting $INVISIBLE_SERVER_POLL_SECS=0.
"""

from __future__ import annotations

import argparse
import hmac
import json
import os
import queue
import secrets
import socket
import sys
import threading
import time
import urllib.error
import urllib.parse
import urllib.request
from http import HTTPStatus  # noqa: F401  (handy for callers extending this)
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from typing import Any

HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(HERE.parent / "lib"))

from config import home, load_env  # noqa: E402
from dashboard_render import (  # noqa: E402
    humanize_age, render_index, render_project, render_not_found,
)
from server_store import Store  # noqa: E402


# ────────────────────────────────────────────────────────────────────────
# Broadcaster (SSE fan-out)
# ────────────────────────────────────────────────────────────────────────

class Broadcaster:
    """One queue per connected SSE client. Publish drops events for slow
    consumers rather than blocking the writer."""
    QUEUE_MAX = 64

    def __init__(self) -> None:
        self._subs: list[queue.Queue] = []
        self._lock = threading.Lock()

    def subscribe(self) -> queue.Queue:
        q: queue.Queue = queue.Queue(maxsize=self.QUEUE_MAX)
        with self._lock:
            self._subs.append(q)
        return q

    def unsubscribe(self, q: queue.Queue) -> None:
        with self._lock:
            try:
                self._subs.remove(q)
            except ValueError:
                pass

    def publish(self, event: dict) -> None:
        with self._lock:
            subs = list(self._subs)
        for q in subs:
            try:
                q.put_nowait(event)
            except queue.Full:
                pass  # slow consumer; they'll catch up via Last-Event-ID on reconnect

    def count(self) -> int:
        with self._lock:
            return len(self._subs)


# ────────────────────────────────────────────────────────────────────────
# Local poller (VPS-native runs)
# ────────────────────────────────────────────────────────────────────────

def local_poll_loop(store: Store, broadcaster: Broadcaster,
                    interval_s: int, log) -> None:
    """Watch this VPS's own $INVISIBLE_HOME/worktrees/ for checkpoints. Any
    file content change is ingested as if a remote machine had pushed it."""
    hostname = socket.gethostname()
    seen_mtimes: dict[Path, float] = {}
    while True:
        try:
            root = home() / "worktrees"
            if root.exists():
                for cp in root.glob("*/feature/.invisible-checkpoint.json"):
                    try:
                        mtime = cp.stat().st_mtime
                    except OSError:
                        continue
                    if seen_mtimes.get(cp) == mtime:
                        continue
                    seen_mtimes[cp] = mtime
                    try:
                        state = json.loads(cp.read_text())
                    except (OSError, json.JSONDecodeError):
                        continue
                    project = state.get("project") or cp.parent.parent.name
                    eid = store.ingest_checkpoint(hostname, project, state)
                    if eid > 0:
                        log(f"[poll] ingested {project} from local fs (event {eid})")
                        broadcaster.publish({
                            "id": eid, "machine": hostname, "project": project,
                            "kind": "checkpoint",
                        })
        except Exception as e:  # noqa: BLE001 — log & keep going
            log(f"[poll] error: {e}")
        time.sleep(interval_s)


# ────────────────────────────────────────────────────────────────────────
# Project-row shaping for the renderer
# ────────────────────────────────────────────────────────────────────────

def shape_for_index(row: dict) -> dict:
    """Turn a {machine, project, state} record into the dict-shape that
    dashboard_render.render_index() expects for a project card."""
    state = row["state"]
    return {
        "project":    row["project"],
        "state":      "RUN" if _is_pid_alive(row["machine"], row["project"]) else "idle",
        "iter":       state.get("iteration", 0),
        "max_iters":  state.get("max_iters") or 0,
        "verdict":    state.get("last_verdict") or "",
        "sha":        state.get("last_sha") or "",
        "host":       row["machine"] or state.get("host") or "?",
        "age":        humanize_age(row["updated_at"]),
        "cost_usd":   round(float((state.get("usage_total") or {}).get("cost_usd", 0.0)), 4),
        "task_first": (state.get("task") or "").splitlines()[0][:200],
    }


def shape_for_detail(row: dict) -> dict:
    state = row["state"]
    return {
        "project":             row["project"],
        "state":               "RUN" if _is_pid_alive(row["machine"], row["project"]) else "idle",
        "host":                row["machine"] or state.get("host"),
        "iter":                state.get("iteration", 0),
        "max_iters":           state.get("max_iters", 0),
        "last_sha":            state.get("last_sha"),
        "last_verdict":        state.get("last_verdict"),
        "last_summary":        state.get("last_summary"),
        "task":                state.get("task"),
        "started_age":         humanize_age(state.get("started_at", "")),
        "updated_age":         humanize_age(state.get("updated_at", "")),
        "usage_total":         state.get("usage_total") or {},
        "usage_per_iter":      state.get("usage_per_iter") or [],
        "feedback_history":    state.get("feedback_history") or [],
    }


def _is_pid_alive(machine: str, project: str) -> bool:
    """Only meaningful for runs on THIS machine — we can't probe pids on
    other hosts. For remote rows we return False; the laptop's last-pushed
    state still shows the right verdict/iter."""
    if machine != socket.gethostname():
        return False
    pf = home() / "run" / f"{project}.pid"
    if not pf.exists():
        return False
    try:
        pid = int(pf.read_text().strip())
        os.kill(pid, 0)
        return True
    except (OSError, ValueError, ProcessLookupError):
        return False


# ────────────────────────────────────────────────────────────────────────
# Notion passthrough (reviews tab) — identical to invisible-dashboard's
# ────────────────────────────────────────────────────────────────────────

def fetch_recent_reviews(n: int = 20) -> list[dict]:
    tok = os.environ.get("NOTION_TOKEN")
    db = os.environ.get("NOTION_DB_REVIEWS")
    if not tok or not db:
        return []
    req = urllib.request.Request(
        f"https://api.notion.com/v1/databases/{db}/query",
        method="POST",
        headers={
            "Authorization": f"Bearer {tok}",
            "Notion-Version": "2022-06-28",
            "Content-Type": "application/json",
        },
        data=json.dumps({
            "sorts": [{"property": "Created", "direction": "descending"}],
            "page_size": min(max(n, 1), 100),
        }).encode(),
    )
    try:
        with urllib.request.urlopen(req, timeout=15) as r:
            body = json.loads(r.read())
    except (urllib.error.URLError, urllib.error.HTTPError, ValueError):
        return []
    results = []
    for page in body.get("results", []):
        props = page.get("properties", {})
        def _rt(key):
            p = props.get(key, {}); t = p.get("type")
            if t == "title":     return "".join(x.get("plain_text", "") for x in p.get("title", []))
            if t == "rich_text": return "".join(x.get("plain_text", "") for x in p.get("rich_text", []))
            if t == "select":    return (p.get("select") or {}).get("name", "")
            if t == "number":    return p.get("number")
            if t == "date":      return (p.get("date") or {}).get("start", "")
            return ""
        results.append({
            "title":   _rt("Title"),
            "iter":    _rt("Iteration"),
            "agent":   _rt("Agent"),
            "verdict": _rt("Verdict"),
            "summary": _rt("Summary"),
            "diff_sha": _rt("Diff SHA"),
            "created": _rt("Created"),
            "age":     humanize_age(_rt("Created") or ""),
        })
    return results


# ────────────────────────────────────────────────────────────────────────
# HTTP handler
# ────────────────────────────────────────────────────────────────────────

class ServerHandler(BaseHTTPRequestHandler):
    server_version = "invisible-server/1"

    def log_message(self, format, *args):  # noqa: A002, ARG002
        return  # silent; we log auth failures + ingests ourselves

    # ---- auth ----
    def _token_from_request(self) -> str | None:
        hdr = self.headers.get("Authorization", "")
        if hdr.startswith("Bearer "):
            return hdr[7:].strip()
        q = urllib.parse.parse_qs(urllib.parse.urlparse(self.path).query)
        return q["token"][0] if "token" in q else None

    def _auth_ok(self) -> bool:
        if self.server.no_auth:  # type: ignore[attr-defined]
            return True
        expected = self.server.auth_token  # type: ignore[attr-defined]
        got = self._token_from_request() or ""
        return hmac.compare_digest(expected, got)

    # ---- response helpers ----
    def _send(self, body: bytes, status: int, ctype: str,
              extra_headers: dict[str, str] | None = None) -> None:
        self.send_response(status)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        for k, v in (extra_headers or {}).items():
            self.send_header(k, v)
        self.end_headers()
        try:
            self.wfile.write(body)
        except (BrokenPipeError, ConnectionResetError):
            pass

    def _html(self, body: str, status: int = 200) -> None:
        self._send(body.encode("utf-8"), status, "text/html; charset=utf-8")

    def _json(self, obj: Any, status: int = 200) -> None:
        self._send(json.dumps(obj, indent=2).encode("utf-8"),
                   status, "application/json; charset=utf-8")

    def _text(self, body: str, status: int = 200) -> None:
        self._send(body.encode("utf-8"), status, "text/plain; charset=utf-8")

    # ---- routing ----
    def do_GET(self) -> None:  # noqa: N802
        path = urllib.parse.urlparse(self.path).path

        if path == "/healthz":
            self._text("ok\n")
            return

        if not self._auth_ok():
            sys.stderr.write(f"[server] auth failed from {self.client_address[0]} for {path}\n")
            self._text("unauthorized\n", 401)
            return

        token = self._token_from_request()
        store: Store = self.server.store          # type: ignore[attr-defined]

        if path in ("/", ""):
            rows = [shape_for_index(r) for r in store.list_projects()]
            reviews = fetch_recent_reviews(20)
            sse_qs = "/api/stream"
            self._html(render_index(rows, reviews, token,
                                    sse_path=sse_qs,
                                    subtitle=f"{socket.gethostname()} (server)"))
            return

        if path.startswith("/p/"):
            project = urllib.parse.unquote(path[3:].rstrip("/"))
            row = store.get_project(project)
            if not row:
                self._html(render_not_found(project, token,
                                            subtitle=f"{socket.gethostname()} (server)"),
                           404)
                return
            self._html(render_project(shape_for_detail(row), token,
                                      sse_path="/api/stream",
                                      subtitle=f"{socket.gethostname()} (server)"))
            return

        if path == "/api/projects":
            self._json([shape_for_index(r) for r in store.list_projects()])
            return

        if path.startswith("/api/p/"):
            project = urllib.parse.unquote(path[7:].rstrip("/"))
            row = store.get_project(project)
            if not row:
                self._json({"error": "not found", "project": project}, 404)
                return
            self._json(shape_for_detail(row))
            return

        if path == "/api/reviews":
            q = urllib.parse.parse_qs(urllib.parse.urlparse(self.path).query)
            n = int(q.get("n", ["20"])[0])
            self._json(fetch_recent_reviews(n))
            return

        if path == "/api/stream":
            self._handle_sse()
            return

        self._text("not found\n", 404)

    def do_POST(self) -> None:  # noqa: N802
        path = urllib.parse.urlparse(self.path).path
        if not self._auth_ok():
            sys.stderr.write(f"[server] auth failed from {self.client_address[0]} for POST {path}\n")
            self._text("unauthorized\n", 401)
            return

        if path == "/api/events":
            self._handle_ingest()
            return

        self._text("not found\n", 404)

    # ---- /api/events ingest ----
    def _handle_ingest(self) -> None:
        store: Store = self.server.store              # type: ignore[attr-defined]
        broadcaster: Broadcaster = self.server.broadcaster  # type: ignore[attr-defined]
        try:
            length = int(self.headers.get("Content-Length", "0"))
            raw = self.rfile.read(length) if length else b""
            body = json.loads(raw or b"{}")
        except (ValueError, json.JSONDecodeError) as e:
            self._json({"error": "invalid json", "detail": str(e)}, 400)
            return

        # Expected shape: {"machine": "abhishek-mbp", "project": "p1",
        #                  "state": {<full checkpoint dict>}}
        machine = (body.get("machine") or "").strip()
        project = (body.get("project") or "").strip()
        state = body.get("state")
        if not machine or not project or not isinstance(state, dict):
            self._json({"error": "machine, project, and state(dict) required"}, 400)
            return

        eid = store.ingest_checkpoint(machine, project, state)
        if eid > 0:
            sys.stderr.write(f"[server] ingest {machine}/{project} → event {eid}\n")
            broadcaster.publish({
                "id": eid, "machine": machine, "project": project,
                "kind": "checkpoint",
            })
        self._json({"ok": True, "event_id": eid, "deduped": eid == 0})

    # ---- /api/stream SSE ----
    def _handle_sse(self) -> None:
        store: Store = self.server.store              # type: ignore[attr-defined]
        broadcaster: Broadcaster = self.server.broadcaster  # type: ignore[attr-defined]

        # SSE replay support: clients reconnecting send Last-Event-ID; we
        # flush any events with id > that before going live.
        last_id_hdr = self.headers.get("Last-Event-ID", "0")
        try:
            last_id = int(last_id_hdr)
        except ValueError:
            last_id = 0

        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-store")
        self.send_header("X-Accel-Buffering", "no")  # nginx: disable proxy buffering
        self.send_header("Connection", "close")  # http.server can't keep-alive on long streams anyway
        self.end_headers()

        q = broadcaster.subscribe()
        try:
            # 1) Replay missed events
            for ev in store.events_since(last_id):
                self._write_sse_event(ev["id"], {
                    "id": ev["id"], "machine": ev["machine"],
                    "project": ev["project"], "kind": ev["kind"],
                })

            # 2) Then stream live. Send a comment ping every 25s as a
            #    keep-alive — Cloudflare drops idle streams at ~100s.
            last_ping = time.monotonic()
            while True:
                try:
                    ev = q.get(timeout=10)
                except queue.Empty:
                    if time.monotonic() - last_ping > 25:
                        try:
                            self.wfile.write(b": ping\n\n")
                            self.wfile.flush()
                            last_ping = time.monotonic()
                        except (BrokenPipeError, ConnectionResetError):
                            break
                    continue
                self._write_sse_event(ev["id"], ev)
        finally:
            broadcaster.unsubscribe(q)

    def _write_sse_event(self, event_id: int, payload: dict) -> None:
        msg = f"id: {event_id}\ndata: {json.dumps(payload)}\n\n".encode()
        try:
            self.wfile.write(msg)
            self.wfile.flush()
        except (BrokenPipeError, ConnectionResetError):
            raise


# ────────────────────────────────────────────────────────────────────────
# main
# ────────────────────────────────────────────────────────────────────────

def serve(host: str, port: int, token: str, no_auth: bool,
          db_path: str, poll_secs: int) -> None:
    store = Store(db_path)
    broadcaster = Broadcaster()

    def log(msg: str) -> None:
        sys.stderr.write(msg + "\n")
        sys.stderr.flush()

    if poll_secs > 0:
        t = threading.Thread(
            target=local_poll_loop, args=(store, broadcaster, poll_secs, log),
            daemon=True, name="local-poller",
        )
        t.start()
        log(f"[server] local poller active (every {poll_secs}s)")
    else:
        log("[server] local poller disabled (INVISIBLE_SERVER_POLL_SECS=0)")

    # Periodic prune so events table doesn't grow forever
    def prune_loop():
        while True:
            time.sleep(3600)
            try:
                deleted = store.prune_events(keep=5000)
                if deleted:
                    log(f"[server] pruned {deleted} old events")
            except Exception as e:  # noqa: BLE001
                log(f"[server] prune error: {e}")
    threading.Thread(target=prune_loop, daemon=True, name="event-prune").start()

    httpd = ThreadingHTTPServer((host, port), ServerHandler)
    httpd.store = store               # type: ignore[attr-defined]
    httpd.broadcaster = broadcaster   # type: ignore[attr-defined]
    httpd.auth_token = token          # type: ignore[attr-defined]
    httpd.no_auth = no_auth           # type: ignore[attr-defined]
    httpd.daemon_threads = True

    log(f"[server] listening on http://{host}:{port}")
    log(f"[server] db: {db_path}")
    if not no_auth:
        log(f"[server] bearer token required (INVISIBLE_SERVER_TOKEN)")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        log("\n[server] shutting down")
        httpd.shutdown()
        store.close()


def main() -> int:
    ap = argparse.ArgumentParser(prog="invisible-server")
    ap.add_argument("--host", default="127.0.0.1",
                    help="interface to bind (default 127.0.0.1; use 0.0.0.0 for "
                         "behind-nginx VPS deploys)")
    ap.add_argument("--port", type=int, default=8770)
    ap.add_argument("--no-auth", action="store_true",
                    help="disable bearer auth (only works with --host 127.0.0.1)")
    ap.add_argument("--db", help="SQLite path (default $INVISIBLE_SERVER_DB or "
                                 "/var/lib/invisible/state.db)")
    args = ap.parse_args()

    load_env()

    if args.no_auth and args.host != "127.0.0.1":
        print("[server] --no-auth requires --host 127.0.0.1", file=sys.stderr)
        return 2

    token = os.environ.get("INVISIBLE_SERVER_TOKEN", "")
    if not args.no_auth and not token:
        token = secrets.token_urlsafe(24)
        print(f"[server] generated INVISIBLE_SERVER_TOKEN={token}")
        print(f"         persist it in this machine's .env or systemd Environment=")

    db_path = (args.db
               or os.environ.get("INVISIBLE_SERVER_DB")
               or "/var/lib/invisible/state.db")
    # Default db path may not be writable in dev — fall back to ~/.invisible.
    try:
        Path(db_path).parent.mkdir(parents=True, exist_ok=True)
    except PermissionError:
        db_path = str(home() / "state.db")
        print(f"[server] /var/lib/invisible not writable; falling back to {db_path}")

    try:
        poll_secs = int(os.environ.get("INVISIBLE_SERVER_POLL_SECS", "10"))
    except ValueError:
        poll_secs = 10

    serve(args.host, args.port, token, args.no_auth, db_path, poll_secs)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
