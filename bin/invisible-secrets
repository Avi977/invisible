#!/usr/bin/env python3
"""invisible-secrets — manage the Infisical-backed secret store.

Subcommands:
    ls            list secret keys reachable with current creds (no values)
    pull          dump all secrets as `export KEY=VALUE` lines (handle with care)
    push          read ~/.invisible/.env and upload every non-bootstrap key
                  to Infisical (creates new secrets, updates existing ones)
    doctor        confirm bootstrap creds resolve + login works + N secrets visible

Bootstrap creds (must be in ~/.invisible/.env, NOT in Infisical itself):
    INFISICAL_CLIENT_ID
    INFISICAL_CLIENT_SECRET
    INFISICAL_PROJECT_ID

Optional:
    INFISICAL_HOST           (default https://vault.theprofitplatform.com.au)
    INFISICAL_ENVIRONMENT    (default "dev")
    INFISICAL_SECRET_PATH    (default "/")

Usage:
    invisible-secrets ls
    invisible-secrets pull
    invisible-secrets pull > /tmp/secrets.env       # for one-off backup
    invisible-secrets push                          # migrate .env → vault
    invisible-secrets push --dry                    # show what would be pushed
    invisible-secrets doctor
"""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(HERE.parent / "lib"))

# Only the .env loader is wanted here — we explicitly do NOT call
# bootstrap_from_infisical() yet because push needs to see the .env values
# verbatim before they're potentially overridden.
import infisical  # noqa: E402

# Keys that stay in .env and are NEVER pushed to the vault.
# Two reasons something belongs here:
#   1. Bootstrap creds — required to reach the vault, so they can't live in it.
#   2. Non-secret config (paths, numbers) — pushing them to a secret store
#      clutters the audit log for no benefit.
DOTENV_ONLY_KEYS = {
    # Bootstrap creds (the only real secrets that stay on disk)
    "INFISICAL_CLIENT_ID",
    "INFISICAL_CLIENT_SECRET",
    "INFISICAL_PROJECT_ID",
    "INFISICAL_HOST",
    "INFISICAL_ENVIRONMENT",
    "INFISICAL_SECRET_PATH",
    "INFISICAL_TIMEOUT_S",
    # Paths
    "INVISIBLE_HOME",
    "INVISIBLE_SRC",
    "INVISIBLE_SERVER_DB",
    "INVISIBLE_VAULT",
    # Tuning knobs
    "INVISIBLE_CONTEXT_BUDGET",
    "INVISIBLE_REVIEW_DIFF_CAP",
    "INVISIBLE_SERVER_POLL_SECS",
}
BOOTSTRAP_KEYS = DOTENV_ONLY_KEYS  # alias kept for any external scripts


def _home() -> Path:
    return Path(os.path.expanduser(os.environ.get("INVISIBLE_HOME", "~/.invisible")))


def _read_env_file() -> dict[str, str]:
    p = _home() / ".env"
    out: dict[str, str] = {}
    if not p.exists():
        return out
    for line in p.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        out[k.strip()] = v.strip().strip('"').strip("'")
    return out


def _seed_env_from_dotenv() -> None:
    """Manually source .env into os.environ — needed before infisical.make_client()
    because that reads from os.environ for the bootstrap creds."""
    for k, v in _read_env_file().items():
        os.environ.setdefault(k, v)


def _project_info() -> tuple[str, str, str]:
    pid = os.environ.get("INFISICAL_PROJECT_ID", "?")
    env = os.environ.get("INFISICAL_ENVIRONMENT", "dev")
    path = os.environ.get("INFISICAL_SECRET_PATH", "/")
    return pid, env, path


def cmd_ls() -> int:
    client = infisical.make_client()
    if not client:
        return 1
    pid, env, path = _project_info()
    secrets = client.list_secrets(pid, env, path)
    if not secrets:
        print("(no secrets reachable — empty project or missing permissions)")
        return 0
    width = max(len(k) for k in secrets)
    for k in sorted(secrets):
        v = secrets[k] or ""
        print(f"  {k.ljust(width)}  ({len(v)} chars)")
    print(f"\n  {len(secrets)} secret(s) in {pid}/{env}{path}")
    return 0


def cmd_pull() -> int:
    client = infisical.make_client()
    if not client:
        return 1
    pid, env, path = _project_info()
    secrets = client.list_secrets(pid, env, path)
    if not secrets:
        return 0
    for k in sorted(secrets):
        # Single-quote and escape internal quotes — safest for shell `export`.
        escaped = secrets[k].replace("'", "'\\''")
        print(f"export {k}='{escaped}'")
    return 0


def cmd_push(dry: bool, force: bool) -> int:
    env_vars = _read_env_file()
    candidates = {k: v for k, v in env_vars.items()
                  if k not in BOOTSTRAP_KEYS and v and not _looks_placeholder(v)}
    if not candidates:
        print("[push] nothing to upload from .env (skipping bootstrap keys + placeholders)")
        return 0

    print(f"[push] candidates from {_home()}/.env:")
    for k in sorted(candidates):
        print(f"  + {k}  ({len(candidates[k])} chars)")

    if dry:
        print(f"\n[push] --dry — would upload {len(candidates)} secret(s)")
        return 0

    if not force:
        try:
            answer = input(f"\nUpload {len(candidates)} secret(s) to Infisical? [y/N] ").strip().lower()
        except (KeyboardInterrupt, EOFError):
            print("\naborted")
            return 130
        if answer not in ("y", "yes"):
            print("aborted")
            return 0

    client = infisical.make_client()
    if not client:
        return 1
    pid, env, path = _project_info()
    ok = 0; fail = 0
    for k, v in candidates.items():
        if client.upsert_secret(pid, env, k, v, secret_path=path):
            print(f"  ✓ {k}")
            ok += 1
        else:
            print(f"  ✗ {k}")
            fail += 1
    print(f"\n[push] {ok} OK, {fail} failed")
    return 1 if fail else 0


def _looks_placeholder(v: str) -> bool:
    return "xxxxxxxx" in v or v == v[:1] * len(v) or v.startswith("secret_xxx")


def cmd_doctor() -> int:
    print("[doctor] checking Infisical configuration\n")
    host = os.environ.get("INFISICAL_HOST", infisical.DEFAULT_HOST)
    print(f"  host        : {host}")
    cid = os.environ.get("INFISICAL_CLIENT_ID", "")
    print(f"  client_id   : {'(set, ' + str(len(cid)) + ' chars)' if cid else 'UNSET — copy from Infisical machine identity'}")
    csec = os.environ.get("INFISICAL_CLIENT_SECRET", "")
    print(f"  client_sec  : {'(set, ' + str(len(csec)) + ' chars)' if csec else 'UNSET'}")
    pid = os.environ.get("INFISICAL_PROJECT_ID", "")
    print(f"  project_id  : {pid or 'UNSET — copy from invisible workspace settings'}")
    env = os.environ.get("INFISICAL_ENVIRONMENT", infisical.DEFAULT_ENV)
    path = os.environ.get("INFISICAL_SECRET_PATH", infisical.DEFAULT_SECRET_PATH)
    print(f"  environment : {env}")
    print(f"  secret_path : {path}\n")

    if not infisical.configured():
        print("[doctor] FAIL — missing bootstrap creds; nothing to test")
        return 1

    client = infisical.make_client()
    if not client:
        print("[doctor] FAIL — login() rejected. Check client_id/secret values.")
        return 1
    print("[doctor] login OK")

    secrets = client.list_secrets(pid, env, path)
    print(f"[doctor] reachable: {len(secrets)} secret(s) at {pid}/{env}{path}")
    if secrets:
        print(f"           keys: {', '.join(sorted(secrets))[:200]}")
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(prog="invisible-secrets")
    sub = ap.add_subparsers(dest="cmd", required=True)
    sub.add_parser("ls",   help="list secret keys (no values)")
    sub.add_parser("pull", help="dump as `export KEY=VAL` lines (handle with care)")
    p_push = sub.add_parser("push", help="migrate .env values into Infisical")
    p_push.add_argument("--dry", action="store_true", help="show what would happen, don't upload")
    p_push.add_argument("--force", action="store_true", help="skip the confirm prompt")
    sub.add_parser("doctor", help="verify bootstrap creds + login + reachability")
    args = ap.parse_args()

    _seed_env_from_dotenv()

    if args.cmd == "ls":     return cmd_ls()
    if args.cmd == "pull":   return cmd_pull()
    if args.cmd == "push":   return cmd_push(args.dry, args.force)
    if args.cmd == "doctor": return cmd_doctor()
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
