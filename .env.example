# ──────────────────────────────────────────────────────────────────────
# invisible .env — bootstrap creds only. Everything else lives in Infisical.
# Copy this file to `.env` and fill in the values. The real `.env` is
# gitignored. Run `invisible-secrets push` after filling this in to migrate
# placeholder secrets into the vault, then delete migrated lines from .env.
# ──────────────────────────────────────────────────────────────────────

# ── Infisical (required for vault-backed secrets) ─────────────────────
# 1. Project ID: invisible project → Settings → General → "Project ID"
# 2. Client ID:  Org → Access Control → Identities → invisible-mac → Universal Auth
# 3. Client Secret: same page → "Create Client Secret" (one-time modal)
INFISICAL_CLIENT_ID=""
INFISICAL_CLIENT_SECRET=""
INFISICAL_PROJECT_ID=""

# Optional Infisical overrides — defaults are fine.
# INFISICAL_HOST=https://vault.theprofitplatform.com.au
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_SECRET_PATH=/

# ── Non-secret tuning knobs ───────────────────────────────────────────
INVISIBLE_CONTEXT_BUDGET=150000

# ──────────────────────────────────────────────────────────────────────
# Everything below this line gets pushed to Infisical by
# `invisible-secrets push` and can be deleted from your local .env after.
# ──────────────────────────────────────────────────────────────────────

# Notion (https://www.notion.so/profile/integrations)
# NOTION_TOKEN=""
# NOTION_RUNS_DB_ID=""

# Telegram bot for alerts (@BotFather → message it → curl getUpdates → chat.id)
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""

# Dashboard / server bearer tokens
# INVISIBLE_DASHBOARD_TOKEN=""
# INVISIBLE_SERVER_TOKEN=""
# INVISIBLE_SERVER_URL="http://127.0.0.1:8765"

# Logseq vault path (graph view source)
# INVISIBLE_VAULT="/path/to/your/Logseq/Invisible"
